# ── 2M Code Environment Configuration ────────────────────────────────────────
# Copy to .env and fill in values. .env is in .gitignore — never commit it.
# Bun auto-loads .env from the project root at startup.
# Explicit settings in 2mcode.jsonc always override values set here.

# ── Provider Selection ──────────────────────────────────────────────────────
# anthropic | openai | gemini | deepseek | groq | ollama | openrouter | custom
2MCODE_PROVIDER=anthropic

# ── Model Selection ─────────────────────────────────────────────────────────
# Leave blank to use provider default. Combined with 2MCODE_PROVIDER → "provider/model".
2MCODE_MODEL=

# ── API Credentials — fill in only the one you need ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
# Ollama / LM Studio: no key needed

# ── Custom Endpoint (optional override) ─────────────────────────────────────
2MCODE_BASE_URL=

# ── Safety and Session Limits ───────────────────────────────────────────────
2MCODE_MAX_TURNS=50
2MCODE_PERMISSION_MODE=default
2MCODE_COMPACT_THRESHOLD=0.85

# ── Skills ──────────────────────────────────────────────────────────────────
# Configured via .opencode/2mcode.jsonc skills.paths
# Install: git clone https://github.com/ArafatAhmed-2M/skills.git ~/.2mcode/skills
